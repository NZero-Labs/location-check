# PostgreSQL connection string
# If not set, the server falls back to pre-downloaded static files in public/data/
DATABASE_URL=postgresql://ibge:ibge@localhost:5432/ibge_map

# Set to "true" if your DB requires SSL (e.g. Railway, Supabase, Neon)
DATABASE_SSL=false

# Express server port (default 3001)
PORT=3001
